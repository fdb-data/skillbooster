        </mxCell>

        <!-- 步骤 1 -->
        <mxCell id="bN1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B82F6;strokeColor=none;fontColor=#ffffff;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="514" y="210" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="bS1" value="共情安抚&#10;&lt;span style='color:#8A8F9A;font-size:9px'&gt;先认同情绪、致歉，稳住客户&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#1B1F2B;spacingLeft=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="208" width="210" height="34" as="geometry" />
        </mxCell>

        <!-- 步骤 2 -->
        <mxCell id="bN2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#3B82F6;strokeColor=none;fontColor=#ffffff;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="514" y="250" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="bS2" value="定位问题&#10;&lt;span style='color:#8A8F9A;font-size:9px'&gt;复述+提问，确认真实诉求&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#1B1F2B;spacingLeft=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="248" width="210" height="34" as="geometry" />
