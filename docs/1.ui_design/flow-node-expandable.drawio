        <mxCell id="bS4" value="确认达成&#10;&lt;span style='color:#8A8F9A;font-size:9px'&gt;让客户确认是否接受&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#1B1F2B;spacingLeft=2;" vertex="1" parent="1">
