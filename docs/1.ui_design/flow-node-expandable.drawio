        <mxCell id="bRowAct" value="⋮⋮  ✎  🗑" style="text;html=1;align=right;fontSize=9;fontColor=#C2C6CE;" vertex="1" parent="1">
          <mxGeometry x="690" y="290" width="60" height="14" as="geometry" />
        </mxCell>

        <!-- 添加步骤 -->
        <mxCell id="bAdd" value="+ 添加步骤" style="rounded=1;arcSize=30;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#C9D4E6;fontColor=#8A93A6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="412" width="100" height="22" as="geometry" />
        </mxCell>

        <!-- 分隔线 -->
        <mxCell id="bDivider" value="" style="line;strokeColor=#EFF1F5;strokeWidth=1;" vertex="1" parent="1">
