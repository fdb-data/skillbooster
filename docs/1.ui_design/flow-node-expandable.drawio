          <mxGeometry x="514" y="290" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="bS3" value="给出方案&#10;&lt;span style='color:#8A8F9A;font-size:9px'&gt;提供 1-2 个可执行解决办法&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#1B1F2B;spacingLeft=2;" vertex="1" parent="1">
