          <mxGeometry x="514" y="370" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="bS5" value="闭环回访&#10;&lt;span style='color:#8A8F9A;font-size:9px'&gt;事后跟进，确认彻底解决&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#1B1F2B;spacingLeft=2;" vertex="1" parent="1">
