        <mxCell id="dataTitle" value="数据结构（待你确认）" style="text;html=1;align=left;fontSize=11;fontStyle=1;fontColor=#8A7A33;" vertex="1" parent="1">
          <mxGeometry x="836" y="422" width="280" height="18" as="geometry" />
        </mxCell>
        <mxCell id="dataBody" value="流程节点的 content 升级为 steps[]：&#10;每步 { title, desc }。旧的纯文本 content&#10;首次展开时按行/句拆成步骤，向后兼容。&#10;（具体存法等你点头后再定，先不动代码）" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#6E6535;spacing=2;" vertex="1" parent="1">
          <mxGeometry x="836" y="442" width="296" height="66" as="geometry" />
