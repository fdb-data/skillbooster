        <mxCell id="modal_save" value="保存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6C5CE7;strokeColor=none;fontColor=#FFFFFF;align=center;verticalAlign=middle;arcSize=30;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1545" y="775" width="100" height="34" as="geometry" />
        </mxCell>

        <mxCell id="n1" value="顶部分成两个真实 tab：① 对比测试——做对比的地方（受控条件 + A/B 两栏实时输出 + 底部输入区）；② 验证报告——所有验证结果（汇总 + 逐条裁判结论）都显示在这个 tab。用标签页切换，不要把内容堆在一页里往下滚。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF6CC;strokeColor=#D6B656;align=left;verticalAlign=top;size=18;spacingLeft=8;spacingTop=6;fontColor=#5A4A00;" vertex="1" parent="1">
          <mxGeometry x="1110" y="180" width="560" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="底部“测试集验证”子 tab：①“✨ 一键生成 10 条”——点击后由验证智能体/大模型根据本 skill 的内容，生成约 10 条有代表性的测试指令（生成的内容是动态值，不是写死的文字）。② 每条单行显示、过长截断。③ 行右侧“...”按钮 → 打开多行编辑弹窗（见下方弹窗）改完整内容。保留“+ 手动添加”和“▶ 全部跑”。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF6CC;strokeColor=#D6B656;align=left;verticalAlign=top;size=18;spacingLeft=8;spacingTop=6;fontColor=#5A4A00;" vertex="1" parent="1">
          <mxGeometry x="1110" y="315" width="560" height="225" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="底部“单条输入”子 tab：一个加高、支持多行的输入框（比上一版那种矮单行框高很多），用于临时贴一条指令快速对比。placeholder 必须简短，例如“输入一条测试指令…”，绝不要把内容示例塞进 placeholder。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF6CC;strokeColor=#D6B656;align=left;verticalAlign=top;size=18;spacingLeft=8;spacingTop=6;fontColor=#5A4A00;" vertex="1" parent="1">
          <mxGeometry x="1110" y="910" width="560" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="验证报告 tab：上半“汇总结果”——胜/平/负计数、一句话总结论、token/延迟/成本数字、导出 JSON/MD（有结果前置灰禁用）。下半“逐条结果”——每条用例一行总结论，展开看该条 A/B 输出 + 五维度 胜/平/负 + 一行证据。未跑验证时显示空态或灰色占位短横线，不要显示“这里将显示…”这类句子。维度名是字面文字，胜负与证据是动态值。裁判对哪侧带 Skill 不知情（盲评）。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF6CC;strokeColor=#D6B656;align=left;verticalAlign=top;size=18;spacingLeft=8;spacingTop=6;fontColor=#5A4A00;" vertex="1" parent="1">
          <mxGeometry x="1110" y="1130" width="560" height="225" as="geometry" />
        </mxCell>

      </root>
