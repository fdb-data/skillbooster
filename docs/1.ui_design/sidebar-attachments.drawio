        <!-- ============ 右侧：导出产物结构 ============ -->
        <mxCell id="exportTitle" value="导出 ZIP = 完整标准目录" style="text;html=1;align=left;fontSize=13;fontStyle=1;fontColor=#3a4250;" vertex="1" parent="1">
