{
  "name": "skillbooster",
  "version": "0.1.2",
  "description": "SkillBooster - 经验萃取智能体桌面应用",
  "main": "./out/main/index.js",
  "author": "SkillBooster",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node node_modules/electron/install.js && node -e \"const fs=require('fs'),p=require('path');const d=p.join('node_modules','electron-vite','node_modules','esbuild');const d2=p.join('node_modules','electron-vite','node_modules','@esbuild');try{if(fs.existsSync(d)){fs.rmSync(d,{recursive:true,force:true});console.log('Removed nested esbuild from electron-vite')}if(fs.existsSync(d2)){fs.rmSync(d2,{recursive:true,force:true});console.log('Removed nested @esbuild from electron-vite')}}catch(e){}\""
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.56",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@xyflow/react": "^12.11.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.7.0",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.1",
    "mammoth": "^1.8.0",
    "minipass": "^7.1.3",
    "pdf-parse": "^1.1.1",
    "react-i18next": "^17.0.8",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "happy-dom": "^15.11.7",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.5.2",
    "vitest": "^3.1.2",
    "zustand": "^4.5.4"
  }
}
